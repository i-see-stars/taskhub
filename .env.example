############################
# Application
############################
PROJECT_NAME=TaskHub
DEBUG=false

############################
# Security - REQUIRED
############################
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-use-secrets-token-urlsafe

# Comma-separated list of allowed hosts (production)
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# Comma-separated list of CORS origins (production)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

############################
# Database
############################
DATABASE_URL=postgresql+asyncpg://taskhub:taskhub@localhost:5432/taskhub

# For docker-compose
DATABASE__PORT=5432
DATABASE__DB=taskhub
DATABASE__USERNAME=taskhub
DATABASE__PASSWORD=taskhub

############################
# JWT (Optional - uses SECRET_KEY by default)
############################
# jwt_secret_key=  # Deprecated, use SECRET_KEY
# jwt_access_token_expire_secs=900  # 15 minutes
# jwt_refresh_token_expire_secs=2419200  # 28 days
# jwt_algorithm=HS256

############################
# Password Hashing
############################
# password_bcrypt_rounds=12
