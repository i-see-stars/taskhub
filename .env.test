############################
# Application
############################
PROJECT_NAME=TaskHub
DEBUG=true

############################
# Security - REQUIRED
############################
SECRET_KEY=test-secret-key-for-testing-only-do-not-use-in-production

# Comma-separated list of allowed hosts (test accepts all)
ALLOWED_HOSTS=[]

# Comma-separated list of CORS origins (production)
CORS_ORIGINS=[]

############################
# Database
############################
DATABASE_URL=postgresql+asyncpg://taskhub:taskhub@localhost:5432/taskhub_test

# For docker-compose
DATABASE__PORT=5432
DATABASE__DB=taskhub_test
DATABASE__USERNAME=taskhub
DATABASE__PASSWORD=taskhub

############################
# JWT (Optional - uses SECRET_KEY by default)
############################
# jwt_secret_key=  # Deprecated, use SECRET_KEY
# jwt_access_token_expire_secs=900  # 15 minutes
# jwt_refresh_token_expire_secs=2419200  # 28 days
# jwt_algorithm=HS256

############################
# Password Hashing
############################
# password_bcrypt_rounds=12
